            "--color-accent": "oklch(55% 0.16 25)", "--color-accent-content": "oklch(94% 0.02 25)",
            "--color-neutral": "oklch(28% 0.06 40)", "--color-neutral-content": "oklch(82% 0.06 65)",
            "--color-sparkle": "oklch(75% 0.12 60)",
          }},
          { name: "Cloud Nine", colorScheme: "light", colors: {
            "--color-base-100": "oklch(96% 0.02 240)", "--color-base-200": "oklch(93% 0.04 235)",
            "--color-base-300": "oklch(90% 0.06 230)", "--color-base-content": "oklch(25% 0.06 240)",
            "--color-primary": "oklch(60% 0.16 240)", "--color-primary-content": "oklch(96% 0.02 240)",
            "--color-secondary": "oklch(55% 0.12 260)", "--color-secondary-content": "oklch(96% 0.02 260)",
            "--color-accent": "oklch(65% 0.14 220)", "--color-accent-content": "oklch(96% 0.02 220)",
            "--color-neutral": "oklch(32% 0.06 240)", "--color-neutral-content": "oklch(94% 0.02 240)",
            "--color-sparkle": "oklch(85% 0.10 235)",
          }},
        ];

        const COLOR_PROPS = [
          "--color-base-100", "--color-base-200", "--color-base-300",
          "--color-base-content", "--color-primary", "--color-primary-content",
          "--color-secondary", "--color-secondary-content", "--color-accent",
          "--color-accent-content", "--color-neutral", "--color-neutral-content",
          "--color-sparkle"
        ];

        const SECTION_IDS = [
          "section-hero", "section-nav", "section-blog",
          "section-jamie", "section-contact"
        ];

        const pickRandom = (arr, n) => {
          const copy = [...arr];
          const result = [];
          for (let i = 0; i < n && copy.length; i++) {
            const idx = Math.floor(Math.random() * copy.length);
            result.push(copy.splice(idx, 1)[0]);
          }
          return result;
        };

        const applyRandomPalettes = () => {
          const picks = pickRandom(FANTASTIC_PALETTES, SECTION_IDS.length + 1);
          const rootPalette = picks[0];
          const el = document.documentElement;
          for (const [k, v] of Object.entries(rootPalette.colors)) el.style.setProperty(k, v);
          if (picks.some(p => p.colorScheme === "dark")) el.style.colorScheme = "dark";

          let css = "";
          SECTION_IDS.forEach((id, i) => {
            const palette = picks[i + 1] || picks[0];
            const props = Object.entries(palette.colors)
              .map(([k, v]) => `${k}: ${v}`)
              .join("; ");
            const bg = palette.colors["--color-base-100"].replace(")", " / 0.55)");
            css += `#${id} { ${props}; background-color: ${bg}; color: var(--color-base-content); }\n`;
          });

          const styleEl = document.createElement("style");
          styleEl.id = "fantastic-palette-overrides";
          styleEl.textContent = css;
          document.head.appendChild(styleEl);
        };

        const clearPalette = () => {
          const el = document.documentElement;
          for (const prop of COLOR_PROPS) el.style.removeProperty(prop);
          el.style.removeProperty("color-scheme");
          const existing = document.getElementById("fantastic-palette-overrides");
          if (existing) existing.remove();
        };

        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
            clearPalette();
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            if (theme === "fantastic") applyRandomPalettes();
            else clearPalette();
          }
        };

        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-base-100 relative min-h-screen transition-colors duration-300">
    <.sparkle_background />
    <.robot_background />
    <div class="relative z-10">
      {@inner_content}
    </div>
  </body>
</html>
