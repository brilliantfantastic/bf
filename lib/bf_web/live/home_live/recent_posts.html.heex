<div :if={@recent_posts != []} class="bg-base-200/80 rounded-box p-6">
  <h3 class="font-display text-xl mb-4">Recent posts</h3>
  <ul class="space-y-3">
    <li :for={post <- @recent_posts}>
      <.link navigate={~p"/blog/#{post.id}"} class="text-base-content/70 hover:text-primary transition-colors">
        {post.title}
      </.link>
    </li>
  </ul>
</div>
